{
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/client",
  "installCommand": "npm install --include=dev",
  "crons": [
    {
      "path": "/api/cron/overdue",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
