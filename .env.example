# Database Configuration
# Neon/Vercel: set DATABASE_URL to your Neon pooled or direct Postgres URL.
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_fight_club

# Optional local fallback if DATABASE_URL is not set.
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=ai_fight_club

# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=your-secret-key-change-in-production
CRON_SECRET=

# Frontend
# Leave empty for same-origin Vercel API or local Vite proxy.
VITE_API_URL=http://localhost:3000

# External APIs (optional)
GITHUB_TOKEN=
