# Database Configuration
# For Neon: Get from https://console.neon.tech → Connection string → Node.js
# Format: postgresql://user:password@host/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_fight_club

# Optional local fallback if DATABASE_URL is not set (for local development)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=ai_fight_club

# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
CRON_SECRET=your-cron-secret-for-scheduled-tasks

# Frontend
# Leave empty for same-origin Vercel API or local Vite proxy.
VITE_API_URL=http://localhost:3000

# External APIs (optional)
# Get from https://github.com/settings/tokens
GITHUB_API_TOKEN=ghp_your_token_here
